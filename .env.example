# Copy to .env locally, or pass these values to Docker with --env-file.
PORT=3000
DATA_DIR=./data

# Required for live Apify searches. Never commit your real token.
APIFY_TOKEN=

# Modes: cache-first, live, demo
APIFY_MODE=cache-first
APIFY_MAX_RESULTS=8
APIFY_REQUEST_TIMEOUT_MS=300000

# Preferred actor for company employee searches, with RAG as fallback.
APIFY_COMPANY_EMPLOYEES_ACTOR=george.the.developer/linkedin-company-employees-scraper
APIFY_COMPANY_MAX_EMPLOYEES=25
APIFY_SEARCH_ACTOR=apify/rag-web-browser

# Optional Gemini reasoning layer for agentic candidate validation/reranking.
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash
GEMINI_API_BASE=https://aiplatform.googleapis.com/v1/publishers/google/models
GEMINI_ENABLED=true
