# Copy to .env locally, or pass these values to Docker with --env-file.
PORT=3000
DATA_DIR=./data
# HOST defaults to 127.0.0.1 locally; Docker sets 0.0.0.0 in the image.
# HOST=127.0.0.1
# Comma-separated hostnames allowed in the HTTP Host header. localhost and
# loopback are always allowed; set this explicitly before trusted-network hosting.
ALLOWED_HOSTS=

# Private owner/admin login. Public search remains open. Both values are
# mandatory in production/Railway so analytics, history, contacts, and notes
# stay private. Generate a unique password (16+ characters) and a separate
# random secret (32+ bytes).
AUTH_PASSWORD=
AUTH_SESSION_SECRET=
AUTH_SESSION_TTL_SECONDS=604800
# Defaults to true in production/Railway and false for local HTTP. Override only
# when the deployment topology requires it.
# AUTH_COOKIE_SECURE=true
# Login brute-force protection.
AUTH_MAX_FAILURES=10
AUTH_FAILURE_WINDOW_SECONDS=900
# Privacy-conscious aggregate usage analytics and public spend protection.
# Browser identifiers are random first-party cookies; only hashes are persisted.
ANALYTICS_RETENTION_DAYS=90
PUBLIC_SEARCHES_PER_VISITOR_PER_DAY=3
PUBLIC_SEARCHES_GLOBAL_PER_DAY=25
# Bound untrusted public search persistence on the attached volume.
SEARCH_HISTORY_MAX_ENTRIES=500
RAW_RUN_CACHE_MAX_FILES=500
# Defaults to true in production/Railway so forwarded client IPs can be used for
# login throttling. Leave unset for the environment-aware default.
# TRUST_PROXY=true
# Railway supplies RAILWAY_PUBLIC_DOMAIN automatically. It and
# healthcheck.railway.app are added to the Host allowlist automatically.

# ─────────────────────────────────────────────────────────────────────────────
# Apify (REQUIRED for live search) — https://console.apify.com/account/integrations
# This is the discovery engine. Never commit your real token.
# ─────────────────────────────────────────────────────────────────────────────
APIFY_TOKEN=

# Modes: cache-first (reuse trusted contacts/cached live runs), live (always fresh),
# demo (synthetic data). `fixture` is reserved for the offline test harness.
APIFY_MODE=cache-first
APIFY_MAX_RESULTS=12
# Client timeout plus a per-actor-run charge ceiling and concurrency cap.
APIFY_REQUEST_TIMEOUT_MS=90000
APIFY_MAX_TOTAL_CHARGE_USD=0.25
APIFY_DISCOVERY_CONCURRENCY=3

# 1) PRIMARY discovery: structured LinkedIn people search (highest precision).
#    "Short" mode ~= $0.10 per 25-profile search page.
APIFY_PROFILE_SEARCH_ACTOR=harvestapi/linkedin-profile-search
APIFY_PROFILE_SEARCH_MODE=Short
APIFY_PROFILE_SEARCH_ENABLED=true
APIFY_COMPANY_SEARCH_ACTOR=harvestapi/linkedin-company-search
# Deep surname sweep: for company searches, also run N harvestapi lastNames[] passes
# over the top Armenian surnames. Finds Armenians who DON'T write "Armenian" on their
# profile (big recall win) but costs ~$0.10 per surname. 0 = off. Try 3-6 for a deep search.
APIFY_SURNAME_SEED_COUNT=0

# 2) Complementary discovery: Google-SERP web search (cheap; strong company recall).
APIFY_SEARCH_ACTOR=apify/rag-web-browser

# 3) Optional broad roster (off by default; most expensive). Turn on for deep company sweeps.
APIFY_COMPANY_EMPLOYEES_ACTOR=george.the.developer/linkedin-company-employees-scraper
APIFY_COMPANY_EMPLOYEES_ENABLED=false
APIFY_COMPANY_MAX_EMPLOYEES=10

# 4) Profile enrichment: full LinkedIn bios for borderline candidates so the LLM judge
#    has real evidence. ~= $0.006 per profile enriched. Capped for cost.
APIFY_ENRICHMENT_ACTOR=anchor/linkedin-profile-enrichment
APIFY_ENRICH_ENABLED=true
APIFY_ENRICH_MAX_PROFILES=6

# A matching trusted contact can satisfy a repeat search without new actor runs.
CONTACT_CACHE_MAX_AGE_DAYS=30

# Apify MCP tool discovery is display-only; off by default to keep it off the hot path.
APIFY_MCP_ENABLED=false
APIFY_MCP_URL=https://mcp.apify.com/?tools=actors,docs,apify/rag-web-browser,harvestapi/linkedin-profile-search

# ─────────────────────────────────────────────────────────────────────────────
# Google Gemini — planning + candidate validation/reranking.
# IMPORTANT: A Vertex AI / AI Studio "Express" key (starts with "AQ.") works ONLY via
# the aiplatform.googleapis.com publisher endpoint below, NOT the standard
# generativelanguage.googleapis.com API. Set GEMINI_API_KEY to that key.
# GOOGLE_CLOUD_API_KEY is accepted as an alias.
# ─────────────────────────────────────────────────────────────────────────────
GEMINI_API_KEY=
GEMINI_MODEL=gemini-3.5-flash
GEMINI_API_BASE=https://aiplatform.googleapis.com/v1/publishers/google/models
GEMINI_ENABLED=true

# Optional Telegram bot. Run with: npm run bot
TELEGRAM_BOT_TOKEN=
# Required when the bot is enabled; comma-separated private chat/group IDs.
TELEGRAM_ALLOWED_CHAT_IDS=
TELEGRAM_DEFAULT_MODE=agent
TELEGRAM_DEFAULT_LIMIT=5
